@page
@model ProiectWeb.Pages.Client.IstoricModel
@{
    ViewData["Title"] = "Istoric Comenzi";
}

<div class="container py-5">
    <div class="ec-page-header mb-4">
        <h1>Istoric comenzi</h1>
        <p class="text-muted mb-0">
            Comenzile plasate pe contul tău.
            @if (Model.TotalOrders > 0 && Model.TotalPages > 1)
            {
                <span> — pagina @Model.PageNumber din @Model.TotalPages</span>
            }
        </p>
    </div>

    @if (Model.Orders != null && Model.Orders.Any())
    {
        <div class="accordion" id="ordersAccordion">
            @foreach (var order in Model.Orders)
            {
                var collapseId = "collapse_" + order.Id;
                var headingId = "heading_" + order.Id;

                // 🧮 Calculăm totalul pe loc, deoarece nu este salvat în baza de date
                // Suma (Cantitate * Preț) pentru fiecare produs din listă
                decimal orderTotal = order.Items.Sum(i => i.Quantity * (i.Product?.Price ?? 0));

                <div class="accordion-item shadow-sm mb-3 border">
                    <h2 class="accordion-header" id="@headingId">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                            <div class="d-flex w-100 justify-content-between align-items-center pe-3 flex-wrap">
                                <div>
                                    <strong>Comanda #@(Model.OrderDisplayNumbers.GetValueOrDefault(order.Id, order.Id))</strong>
                                    <span class="text-muted ms-2 small">
                                        @order.OrderDate.ToString("dd MMM yyyy, HH:mm")
                                    </span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <span class="badge bg-success me-3">Plasată</span>
                                    <span class="fw-bold text-primary">@orderTotal.ToString("0.00") RON</span>
                                </div>
                            </div>
                        </button>
                    </h2>
                    <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId" data-bs-parent="#ordersAccordion">
                        <div class="accordion-body bg-light">

                            <div class="table-responsive">
                                <table class="table table-sm table-borderless align-middle mb-0">
                                    <thead class="bg-white border-bottom">
                                        <tr class="text-muted">
                                            <th>Produs</th>
                                            <th class="text-center">Cantitate</th>
                                            <th class="text-end">Preț unitar</th>
                                            <th class="text-end">Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in order.Items)
                                        {
                                            // Verificăm dacă produsul mai există (nu e null)
                                            var price = item.Product?.Price ?? 0;
                                            var rowTotal = item.Quantity * price;
                                            var imgUrl = ProductImages.GetUrl(item.Product);

                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <img src="@imgUrl"
                                                             style="width: 40px; height: 40px; object-fit: cover; border-radius:4px;" class="me-2 border">
                                                        <span>@(item.Product?.Name ?? "Produs indisponibil")</span>
                                                    </div>
                                                </td>
                                                <td class="text-center">x @item.Quantity</td>
                                                <td class="text-end">@price.ToString("0.00") RON</td>
                                                <td class="text-end fw-bold">@rowTotal.ToString("0.00") RON</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot class="border-top bg-white">
                                        <tr>
                                            <td colspan="3" class="text-end fw-bold pt-3">Total Comandă:</td>
                                            <td class="text-end fw-bold text-primary fs-5 pt-3">@orderTotal.ToString("0.00") RON</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Paginare comenzi" class="mt-4">
                <ul class="pagination justify-content-center ec-admin-pagination mb-0">
                    <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                        <a class="page-link" href="@(Url.Page(null, new { pageNumber = Model.PageNumber - 1 }) ?? "#")">&laquo;</a>
                    </li>
                    @{
                        int startPage = Math.Max(1, Model.PageNumber - 2);
                        int endPage = Math.Min(Model.TotalPages, startPage + 4);
                        if (endPage - startPage < 4) startPage = Math.Max(1, endPage - 4);
                    }
                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link" href="@(Url.Page(null, new { pageNumber = i }) ?? "#")">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="@(Url.Page(null, new { pageNumber = Model.PageNumber + 1 }) ?? "#")">&raquo;</a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="text-center py-5">
            <h3 class="mt-0">Nu ai plasat nicio comandă încă.</h3>
            <p class="text-muted">Explorează catalogul pentru a plasa prima comandă.</p>
            <a href="/Client/Products" class="btn btn-ec-primary mt-2">Mergi la magazin</a>
        </div>
    }
</div>