@page
@model ProiectWeb.Areas.Admin.Pages.TopFavoritesModel
@{
    ViewData["Title"] = "Statistici Favorite";
}

<div class="container mt-4">
    <div class="ec-page-header mb-4">
        <h1>Cele mai dorite produse</h1>
        <p class="text-muted mb-0">Produsele adăugate cel mai des la favorite.</p>
    </div>

    <div class="ec-admin-table-wrap">
        <table class="table ec-admin-table align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 50px;">Loc</th>
                        <th>Produs</th>
                        <th class="text-center">Salvări</th>
                        <th class="text-center">Preț</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int rank = 1;
                    }
                    @foreach (var item in Model.PopularProducts)
                    {
                        <tr>
                            <td class="fw-bold text-muted">#@rank</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="@ProductImages.GetUrlByName(item.Name, item.Imagine)"
                                         class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;">
                                    <div>
                                        <div class="fw-bold">@item.Name</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border">@item.Count</span>
                            </td>
                            <td class="text-center text-success fw-bold">@item.Price.ToString("0.00") RON</td>
                        </tr>
                        rank++;
                    }
                </tbody>
        </table>
    </div>
</div>