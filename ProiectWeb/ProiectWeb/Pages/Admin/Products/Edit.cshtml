@page "{id:int}"
@model ProiectWeb.Pages.Admin.Products.EditModel
@{
    ViewData["Title"] = "Editează produs";
}

<div class="ec-admin-header mb-4">
    <h2>Editează produs</h2>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="ec-admin-form-card">
            <form method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="Product.Id" />
                <input type="hidden" asp-for="Product.Imagine" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Product.Name" class="form-label fw-semibold"></label>
                        <input asp-for="Product.Name" class="form-control" />
                        <span asp-validation-for="Product.Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Product.Category" class="form-label fw-semibold"></label>
                        <input asp-for="Product.Category" class="form-control" />
                        <span asp-validation-for="Product.Category" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Product.Price" class="form-label fw-semibold">Preț (RON)</label>
                        <input asp-for="Product.Price" class="form-control" type="number" step="0.01" min="0" max="500" />
                        <span asp-validation-for="Product.Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Product.Quantity" class="form-label fw-semibold">Stoc</label>
                        <input asp-for="Product.Quantity" class="form-control" type="number" min="0" />
                        <span asp-validation-for="Product.Quantity" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Product.Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Product.Description" class="form-control" rows="4"></textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Imagine</label>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <img src="@ProductImages.GetUrl(Model.Product)"
                                 class="ec-admin-thumb" alt="" />
                            <input type="file" asp-for="ImagineFisier" class="form-control" accept="image/*" />
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-ec-primary">Salvează</button>
                    <a asp-page="Index" class="btn btn-outline-secondary">Anulează</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
