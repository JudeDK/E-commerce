@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Resetare parolă";
}

<style>
    .reset-card {
        max-width: 420px;
        margin: 70px auto;
        padding: 35px;
        background: white;
        border-radius: 16px;
        box-shadow: 0 6px 25px rgba(0,0,0,0.12);
        text-align: center;
    }

    .reset-title {
        font-size: 26px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 10px;
    }

    .reset-subtext {
        color: #707070;
        font-size: 15px;
        margin-bottom: 25px;
    }

    .email-icon {
        font-size: 38px;
        color: #3498db;
        margin-bottom: 15px;
    }

    .btn-reset {
        background: #3498db;
        color: white;
        font-size: 18px;
        font-weight: 600;
        padding: 12px 0;
        border-radius: 10px;
        width: 100%;
        border: none;
        transition: 0.2s;
        margin-top: 10px;
    }

        .btn-reset:hover {
            background: #2f89c5;
        }
</style>

<div class="reset-card">

    <i class="bi bi-envelope-paper-fill email-icon"></i>

    <div class="reset-title">Resetare parolă</div>

    <div class="reset-subtext">
        Introdu adresa ta de email.
        Îți vom trimite un link pentru a reseta parola contului.
    </div>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Email"
                   class="form-control"
                   placeholder="email@example.com"
                   autocomplete="username"
                   aria-required="true" />
            <label asp-for="Input.Email"></label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <button type="submit" class="btn-reset">Trimite linkul de resetare</button>
    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
