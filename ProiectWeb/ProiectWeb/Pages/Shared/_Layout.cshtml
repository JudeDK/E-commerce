@using Microsoft.AspNetCore.Identity
@using ProiectWeb.Models
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager

<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — E-commerce</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProiectWeb.styles.css" asp-append-version="true" />
</head>

@{
    var userName = User.Identity?.Name ?? "";
    var currentPath = Context.Request.Path.Value?.ToLower() ?? "";
    var isAuthenticated = SignInManager.IsSignedIn(User);
    var isAdmin = isAuthenticated && User.IsInRole("Admin");
    var isClient = isAuthenticated && User.IsInRole("User");
}

<body class="layout-wrapper" data-user="@userName" data-role="@(isAdmin ? "Admin" : isClient ? "User" : "Guest")">

    <header>
        <nav class="navbar navbar-expand-lg ec-navbar sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-page="/Index">
                    <span class="ec-brand-name">E-commerce</span>
                    <span class="ec-brand-tag">magazin online</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarContent" aria-controls="navbarContent"
                        aria-expanded="false" aria-label="Meniu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (!isAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentPath == "/" || currentPath == "/index" ? "active" : "")" asp-page="/Index">Acasă</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentPath.Contains("/about") ? "active" : "")" asp-page="/About">Despre</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Magazin</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentPath.Contains("/contact") ? "active" : "")" asp-page="/Contact">Contact</a>
                            </li>
                        }
                        else if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentPath.Contains("/admin/products") ? "active" : "")" asp-page="/Admin/Products/Index">Produse</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentPath.Contains("/admin/notifications") ? "active" : "")" asp-page="/Admin/Notifications/Index">Notificări</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentPath.Contains("/admin/orders") ? "active" : "")" asp-page="/Admin/Orders/Index">Comenzi</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentPath.Contains("/topfavorites") ? "active" : "")" asp-page="/Admin/TopFavorites">Favorite</a>
                            </li>
                        }
                        else if (isClient)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentPath == "/" || currentPath == "/index" ? "active" : "")" asp-page="/Index">Acasă</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentPath.Contains("/about") ? "active" : "")" asp-page="/About">Despre</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentPath.Contains("/products") ? "active" : "")" asp-page="/Client/Products/Index">Magazin</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentPath.Contains("/cart") ? "active" : "")" asp-page="/Client/Cart/Index">Coș</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentPath.Contains("/favorites") ? "active" : "")" asp-page="/Client/Favorites/Index">Favorite</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentPath.Contains("/contact") ? "active" : "")" asp-page="/Contact">Contact</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-grow-1 py-4">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    @if (isAdmin)
    {
        <div id="admin-chat-launcher" onclick="toggleAdminChat()" class="admin-chat-dock">
            <span>Analiză stoc</span>
        </div>
        <div id="chat-box" class="admin-chat-sidebar hidden">
            <div class="chat-header-admin">
                <h5 class="m-0">Panou analiză</h5>
                <button type="button" class="btn-close btn-close-white" onclick="toggleAdminChat()"></button>
            </div>
            <div class="admin-quick-actions p-2">
                <button class="btn btn-xs btn-outline-secondary" onclick="window.sendAdminCommand('admin_stoc_stagnant_30')">Stagnant</button>
                <button class="btn btn-xs btn-outline-secondary" onclick="window.sendAdminCommand('admin_stoc_critic')">Stoc critic</button>
                <button class="btn btn-xs btn-outline-secondary" onclick="window.sendAdminCommand('admin_analiza_favorite')">Favorite</button>
                <button class="btn btn-xs btn-ec-primary btn-xs" onclick="window.sendAdminCommand('admin_propunere_comenzi')">Comenzi</button>
            </div>
            <div id="chat-messages" class="chat-body-admin flex-grow-1"></div>
            <div class="chat-footer p-3 border-top">
                <p class="small text-muted mb-0 text-center">Selectează o acțiune de mai sus.</p>
                <input type="text" id="chat-input" class="form-control d-none" disabled readonly tabindex="-1" aria-hidden="true" />
                <button type="button" id="chat-send" class="d-none" disabled aria-hidden="true"></button>
            </div>
        </div>
    }
    else if (isClient)
    {
        <div id="chat-container">
            <button type="button" id="chat-toggle" aria-label="Deschide suport tehnic"></button>
            <div id="chat-box" class="hidden">
                <div class="chat-panel-header px-3 py-2 border-bottom fw-semibold small">Suport clienți</div>
                <div id="chat-messages" style="max-height: 300px; overflow-y: auto;"></div>
                <div class="chat-input-area p-2 border-top d-flex gap-2">
                    <input type="text" id="chat-input" class="form-control form-control-sm" placeholder="Mesajul tău..." />
                    <button type="button" id="chat-send" class="btn btn-ec-mint btn-sm">Trimite</button>
                </div>
            </div>
        </div>
    }

    <footer class="ec-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-5">
                    <div class="ec-footer-brand">E-commerce</div>
                    <p class="small mb-0 opacity-75">
                        Magazin online cu produse pentru casă, masă și zi de zi.
                        O echipă mică din București — selectăm, ambalăm și răspundem la mesaje cu grijă.
                    </p>
                </div>
                <div class="col-md-3">
                    <h6 class="text-white mb-3">Magazin</h6>
                    <ul class="list-unstyled small">
                        <li><a asp-page="/Index">Acasă</a></li>
                        <li><a asp-page="/About">Despre noi</a></li>
                        <li><a asp-page="/Contact">Contact</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white mb-3">Contact</h6>
                    <p class="small mb-1">raresmarian3344@gmail.com</p>
                    <p class="small mb-0">+40 700 000 000</p>
                </div>
            </div>
            <hr class="border-secondary my-3 opacity-25" />
            <p class="text-center small mb-0 opacity-75">© @DateTime.Now.Year E-commerce</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function toggleAdminChat() {
            const chatBox = document.getElementById("chat-box");
            const launcher = document.getElementById("admin-chat-launcher");
            if (chatBox?.classList.contains("admin-chat-sidebar")) {
                chatBox.classList.toggle("hidden");
                if (launcher) launcher.style.opacity = chatBox.classList.contains("hidden") ? "1" : "0";
            }
        }
    </script>
    <script src="~/js/chatbox.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
