@page
@model ProiectWeb.Pages.Client.StatisticiModel
@{
    ViewData["Title"] = "Statistici Personale";
}

<div class="container py-5">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div class="ec-page-header mb-0">
            <h1>Analiza cumpărăturilor</h1>
            <p class="text-muted mb-0">Evoluția cheltuielilor și distribuția pe categorii.</p>
        </div>

        <form method="get" id="filterForm">
            <select name="luni" class="form-select" onchange="document.getElementById('filterForm').submit()" style="width: 180px;">
                <option value="3" selected="@(Request.Query["luni"] == "3")">Ultimele 3 luni</option>
                <option value="6" selected="@(Request.Query["luni"] == "6" || string.IsNullOrEmpty(Request.Query["luni"]))">Ultimele 6 luni</option>
                <option value="12" selected="@(Request.Query["luni"] == "12")">Ultimul an</option>
            </select>
        </form>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="ec-stat-card">
                <div class="ec-stat-label">Luna curentă</div>
                <h2>@Model.TotalLunaCurenta.ToString("N2") RON</h2>

                @if (Model.DiferentaProcentuala != 0)
                {
                    @if (Model.DiferentaProcentuala > 0)
                    {
                        <span class="ec-stat-trend up">+@Model.DiferentaProcentuala.ToString("F1")% față de luna trecută</span>
                    }
                    else
                    {
                        <span class="ec-stat-trend down">@Model.DiferentaProcentuala.ToString("F1")% față de luna trecută</span>
                    }
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="ec-chart-card">
                <h5>Istoric cheltuieli</h5>
                <canvas id="lineChart" style="max-height: 350px;"></canvas>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="ec-chart-card">
                <h5>Categorii</h5>
                <canvas id="pieChart" style="max-height: 350px;"></canvas>
                <div id="noDataMessage" class="text-center text-muted mt-4" style="display:none;">
                    Nu există date pentru categorii.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const dataEvolutie = @Html.Raw(Model.DateGraficJson);
        const dataCategorii = @Html.Raw(Model.DateCategoriiJson);

        const ctxLine = document.getElementById('lineChart').getContext('2d');
        new Chart(ctxLine, {
            type: 'line',
            data: {
                labels: dataEvolutie.map(d => d.Eticheta),
                datasets: [{
                    label: 'Cheltuieli (RON)',
                    data: dataEvolutie.map(d => d.Total),
                    borderColor: '#8b3a2a',
                    backgroundColor: 'rgba(139, 58, 42, 0.08)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.3,
                    pointRadius: 3,
                    pointBackgroundColor: '#8b3a2a'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#e8e4dc' } },
                    x: { grid: { display: false } }
                }
            }
        });

        if (dataCategorii.length > 0) {
            const ctxPie = document.getElementById('pieChart').getContext('2d');
            new Chart(ctxPie, {
                type: 'doughnut',
                data: {
                    labels: dataCategorii.map(d => d.Categorie),
                    datasets: [{
                        data: dataCategorii.map(d => d.Suma),
                        backgroundColor: ['#8b3a2a', '#3d5c4a', '#6b5b4f', '#a67c52', '#4a5568', '#718096'],
                        hoverOffset: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { usePointStyle: true, padding: 16 } }
                    }
                }
            });
        } else {
            document.getElementById('pieChart').style.display = 'none';
            document.getElementById('noDataMessage').style.display = 'block';
        }
    </script>
}
