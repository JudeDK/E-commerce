@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Schimbă parola";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />
<div class="row">
    <div class="col-md-6">
        <form id="change-password-form" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" id="oldPassword" />
                <label asp-for="Input.OldPassword" class="form-label"></label>
                <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" id="newPassword" />
                <label asp-for="Input.NewPassword" class="form-label"></label>
                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                <small class="text-muted">Trebuie să fie diferită de parola actuală.</small>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" />
                <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-primary">Salvează parola</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const oldPwd = document.getElementById('oldPassword');
            const newPwd = document.getElementById('newPassword');
            const form = document.getElementById('change-password-form');

            function validateNotSame() {
                if (oldPwd.value && newPwd.value && oldPwd.value === newPwd.value) {
                    newPwd.setCustomValidity('Parola nouă trebuie să fie diferită de parola actuală.');
                } else {
                    newPwd.setCustomValidity('');
                }
            }

            oldPwd?.addEventListener('input', validateNotSame);
            newPwd?.addEventListener('input', validateNotSame);
            form?.addEventListener('submit', validateNotSame);
        })();
    </script>
}
