@page
@model ProiectWeb.Pages.Client.Cart.OrderSuccessModel
@{
    ViewData["Title"] = "Plată reușită";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="ec-admin-card p-4 p-md-5">
                <div class="ec-order-success">
                    <h2 class="fw-bold mb-2">Plată confirmată</h2>
                    <p class="text-muted mb-0">Comanda ta a fost înregistrată. Tranzacția a fost procesată prin Stripe (mod test).</p>
                </div>

                <p class="mb-4">Îți mulțumim — comanda ta a fost înregistrată cu succes.</p>

                <div class="d-flex flex-wrap gap-2">
                    <a href="/Client/Products/Index" class="btn btn-ec-primary">Înapoi la magazin</a>
                    <a href="/Client/Istoric" class="btn btn-outline-secondary">Vezi comenzile mele</a>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Request.Query["sessionId"]))
            {
                <p class="mt-4 text-muted small text-center">
                    ID tranzacție: <code>@Request.Query["sessionId"]</code>
                </p>
            }
        </div>
    </div>
</div>
