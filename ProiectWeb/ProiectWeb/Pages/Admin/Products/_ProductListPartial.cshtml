@model ProiectWeb.Pages.Admin.Products.IndexModel

@if (Model.Products != null && Model.Products.Any())
{
    <div class="ec-admin-table-wrap">
        <table class="table ec-admin-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Produs</th>
                    <th>Preț (RON)</th>
                    <th>Stoc</th>
                    <th>Categorie</th>
                    <th class="d-none d-lg-table-cell">Descriere</th>
                    <th class="text-end">Acțiuni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model.Products)
                {
                    <tr>
                        <td class="fw-semibold">@product.Name</td>
                        <td><span class="badge bg-light text-dark border">@product.Price.ToString("0.00")</span></td>
                        <td>
                            @if (product.Quantity <= 15)
                            {
                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle">@product.Quantity</span>
                            }
                            else
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle">@product.Quantity</span>
                            }
                        </td>
                        <td><span class="ec-admin-cat">@product.Category</span></td>
                        <td class="d-none d-lg-table-cell text-muted small text-truncate" style="max-width:220px;">@product.Description</td>
                        <td class="text-end text-nowrap">
                            <a asp-page="./Edit" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary">Editează</a>
                            <a asp-page="./Delete" asp-route-id="@product.Id" class="btn btn-sm btn-outline-danger">Șterge</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav aria-label="Paginare produse" class="mt-3">
        <ul class="pagination justify-content-center ec-admin-pagination mb-0">
            <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                <a class="page-link" href="javascript:void(0);" onclick="changePage(@(Model.PageNumber - 1))">&laquo;</a>
            </li>
            @{
                int startPage = Math.Max(1, Model.PageNumber - 2);
                int endPage = Math.Min(Model.TotalPages, startPage + 4);
                if (endPage - startPage < 4) startPage = Math.Max(1, endPage - 4);
            }
            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" href="javascript:void(0);" onclick="changePage(@i)">@i</a>
                </li>
            }
            <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="javascript:void(0);" onclick="changePage(@(Model.PageNumber + 1))">&raquo;</a>
            </li>
        </ul>
    </nav>
}
else
{
    <div class="ec-admin-card text-center py-5 text-muted">
        Niciun produs găsit.
    </div>
}
